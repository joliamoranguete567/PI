<!DOCTYPE html>
<html>

<head>
    <title>Clientes</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

    <%- include('../partials/nav') %>

    <div class="container mt-4">
            <!-- FORMULÁRIO -->
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="mb-3"><%= clienteEditar ? '✏️ Editar' : '➕ Novo' %> Cliente</h5>
                    <form action="<%= clienteEditar ? '/clientes/editar/' + clienteEditar.id : '/clientes/salvar' %>" method="POST">
                        <div class="mb-3">
                            <label class="form-label">Nome</label>
                            <input type="text" name="nome" class="form-control form-control-lg" required value="<%= clienteEditar ? clienteEditar.nome : '' %>">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">CPF</label>
                            <input type="text" name="email" class="form-control form-control-lg" required value="<%= clienteEditar ? clienteEditar.email : '' %>">
                        </div>
                       <div class="d-grid">
                        <button class="btn btn-<%= clienteEditar ? 'success' : 'primary' %>"><%= clienteEditar ? 'Atualizar' : 'Salvar' %></button>
 
                        <% if(clienteEditar){ %>
 
                            <a href="/clientes" class="btn btn-secondary mt-2">
                                Cancelar
                            </a>
 
                        <% } %>
                    </div>
                    </form>
                </div>
            </div>


        <div class="container mt-4">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0">📂 clientes</h4>
            </div>

            <!-- 🖥️ DESKTOP (TABELA) -->
            <div class="d-none d-md-block">
                <table class="table table-bordered table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Nome</th>
                            <th widht="100">CPF</th>
                            <th width="150">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% clientes.forEach(cli=> { %>
                            <tr>
                                <td>
                                    <%= cli.id %>
                                </td>
                                <td>
                                    <%= cli.nome %>
                                </td>
                                <td>
                                    <%= cli.email %>
                                </td>
                                <td>
                                    <a href="/clientes/editar/<%= cli.id %>" class="btn btn-warning btn-sm">
                                        Editar
                                    </a>
                                    <a href="/clientes/excluir/<%= cli.id %>" class="btn btn-danger btn-sm"
                                        onclick="return confirm('Deseja excluir este cliente?')">
                                        Excluir
                                    </a>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
            </div>

            <!-- 📱 MOBILE (CARDS) -->
            <div class="d-md-none">
                <% clientes.forEach(cli=> { %>
                    <div class="card mb-3 shadow-sm">
                        <div class="card-body">

                            <h5 class="card-title">
                                <%= cli.nome %>
                            </h5>

                            <p class="card-text text-muted">
                                ID: <%= cli.id %>
                            </p>
                            <p class=""card-tttle>
                                <%= cli.email %>
                            </p>

                            <div class="d-grid gap-2">

                                <a href="/clientes/editar/<%= cli.id %>" class="btn btn-warning btn-sm">
                                    ✏️ Editar
                                </a>

                                <a href="/clientes/excluir/<%= cli.id %>" class="btn btn-danger btn-sm"
                                    onclick="return confirm('Deseja excluir este cliente?')">
                                    ❌ Excluir
                                </a>
                            </div>
                        </div>
                    </div>
                    <% }) %>
            </div>

            <a href="/" class="btn btn-secondary w-100 mt-3">Voltar</a>

        </div>

        <%- include('../partials/footer') %>

</body>

</html>